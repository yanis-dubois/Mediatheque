{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mediatheque",
  "version": "0.1.0",
  "identifier": "com.mediatheque.app",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/mediatheque/browser"
  },
  "app": {
    "windows": [
      {
        "title": "mediatheque",
        "width": 1200,
        "height": 880
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
